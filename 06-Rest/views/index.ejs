<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>All post</title>
</head>
<body>
    <h1>Quora posts</h1>
    <% for(post of posts){ %>
        <div class="post">
            <h3 class="user">@<%= post.username %></h3>
            <h4 class="title"><%= post.title%></h4>
        </div>
    <% } %>

</body>
</html>